(defun as-asin-database (x f)
  (declare (type double-float x f))
  (let ((ax (abs x))
        (a 0)
        (b 29))
    (loop while (< (1+ a) b)
          for m = (floor (+ a b) 2)
          do (if (<= (aref *asin-database* m 0) ax)
                 (setf a m)
                 (setf b m))
          finally  
             (if (= (aref *asin-database* m 0) ax)
                 (if (plusp x)
                     (+ (aref *asin-database* m 1)
                        (aref *asin-database* m 2))
                     (- (- (aref *asin-database* m 1))
                        (aref *asin-database* m 2)))
                 f))))

(defparameter *sin-i/64*
  (make-array
   '(33 2)
   :initial-contents
   (loop for i from 0 to 32
         for ratio = (/ i 64)
         for rational-sine = (sim:rational-sine ratio)
         collect (multiple-value-bind (high low)
                     (double-double-from-rational rational-sine)
                   ;; Notice the order.
                   (list low high)))))
